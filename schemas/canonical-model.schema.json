{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/UtakataKyosui/OpenModels/main/schemas/canonical-model.schema.json",
  "title": "OpenModels Canonical Model",
  "description": "Normalized backend-agnostic IR consumed by generators.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "entities"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "adapters": {
      "$ref": "#/$defs/adapterMap"
    },
    "outputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/output"
      }
    },
    "enums": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/enum"
      }
    },
    "entities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/entity"
      }
    }
  },
  "$defs": {
    "jsonScalar": {
      "type": [
        "string",
        "number",
        "integer",
        "boolean",
        "null"
      ]
    },
    "jsonArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/jsonValue"
      }
    },
    "jsonObject": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/jsonValue"
      }
    },
    "jsonValue": {
      "oneOf": [
        {
          "$ref": "#/$defs/jsonScalar"
        },
        {
          "$ref": "#/$defs/jsonArray"
        },
        {
          "$ref": "#/$defs/jsonObject"
        }
      ]
    },
    "adapterMap": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/jsonObject"
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target"
      ],
      "properties": {
        "target": {
          "type": "string",
          "minLength": 1
        },
        "filename": {
          "type": "string",
          "minLength": 1
        },
        "options": {
          "$ref": "#/$defs/jsonObject"
        }
      }
    },
    "enumValue": {
      "type": [
        "string",
        "integer"
      ]
    },
    "sourceSchemas": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": {
          "type": "string",
          "pattern": "^#/"
        },
        "read": {
          "type": "string",
          "pattern": "^#/"
        },
        "update": {
          "type": "string",
          "pattern": "^#/"
        }
      }
    },
    "enum": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "values"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "adapters": {
          "$ref": "#/$defs/adapterMap"
        },
        "description": {
          "type": "string"
        },
        "sourceSchemas": {
          "$ref": "#/$defs/sourceSchemas"
        },
        "values": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/enumValue"
          }
        }
      }
    },
    "computed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expression",
        "stored"
      ],
      "properties": {
        "expression": {
          "type": "string",
          "minLength": 1
        },
        "stored": {
          "type": "boolean"
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type",
        "nullable",
        "persisted",
        "generated"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "adapters": {
          "$ref": "#/$defs/adapterMap"
        },
        "storageName": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "length": {
          "type": "integer",
          "minimum": 1
        },
        "precision": {
          "type": "integer",
          "minimum": 1
        },
        "scale": {
          "type": "integer",
          "minimum": 0
        },
        "enum": {
          "type": "string",
          "minLength": 1
        },
        "primaryKey": {
          "type": "boolean"
        },
        "unique": {
          "type": "boolean"
        },
        "nullable": {
          "type": "boolean"
        },
        "persisted": {
          "type": "boolean"
        },
        "generated": {
          "type": "string",
          "enum": [
            "none",
            "database",
            "application"
          ]
        },
        "default": {
          "type": [
            "string",
            "number",
            "integer",
            "boolean",
            "null"
          ]
        },
        "computed": {
          "$ref": "#/$defs/computed"
        },
        "sourceSchemas": {
          "$ref": "#/$defs/sourceSchemas"
        }
      }
    },
    "index": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fields",
        "unique"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "adapters": {
          "$ref": "#/$defs/adapterMap"
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "unique": {
          "type": "boolean"
        }
      }
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entity",
        "fields"
      ],
      "properties": {
        "entity": {
          "type": "string",
          "minLength": 1
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "onDelete": {
          "type": "string",
          "enum": [
            "noAction",
            "restrict",
            "cascade",
            "setNull",
            "setDefault"
          ]
        },
        "onUpdate": {
          "type": "string",
          "enum": [
            "noAction",
            "restrict",
            "cascade",
            "setNull",
            "setDefault"
          ]
        }
      }
    },
    "constraint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "adapters": {
          "$ref": "#/$defs/adapterMap"
        },
        "kind": {
          "type": "string",
          "enum": [
            "primaryKey",
            "unique",
            "foreignKey",
            "check"
          ]
        },
        "fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "references": {
          "$ref": "#/$defs/reference"
        },
        "expression": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "kind",
        "targetEntity",
        "ownership"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "adapters": {
          "$ref": "#/$defs/adapterMap"
        },
        "kind": {
          "type": "string",
          "enum": [
            "belongsTo",
            "hasOne",
            "hasMany",
            "manyToMany"
          ]
        },
        "targetEntity": {
          "type": "string",
          "minLength": 1
        },
        "ownership": {
          "type": "string",
          "enum": [
            "owner",
            "inverse"
          ]
        },
        "foreignKey": {
          "type": "string",
          "minLength": 1
        },
        "references": {
          "type": "string",
          "minLength": 1
        },
        "throughEntity": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "table",
        "fields"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "adapters": {
          "$ref": "#/$defs/adapterMap"
        },
        "table": {
          "type": "string",
          "minLength": 1
        },
        "sourceSchemas": {
          "$ref": "#/$defs/sourceSchemas"
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/field"
          }
        },
        "relations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relation"
          }
        },
        "indexes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/index"
          }
        },
        "constraints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/constraint"
          }
        }
      }
    }
  }
}
